{
  "name": "mcpanel",
  "version": "1.0.0",
  "description": "Minecraft Server Manager",
  "main": "main.js",
  "author": "MCPanel Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/mcpanel.git"
  },
  "keywords": [
    "minecraft",
    "server",
    "manager",
    "electron",
    "paper",
    "spigot",
    "fabric",
    "forge"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:all": "electron-builder -mwl",
    "clean": "rimraf dist node_modules/.cache",
    "lint": "echo 'Linting not configured yet'"
  },
  "build": {
    "appId": "com.mcpanel.app",
    "productName": "MCPanel",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "public/**"
    ]
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "rimraf": "^6.1.3",
    "sql.js": "^1.12.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}
